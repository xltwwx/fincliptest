.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: block;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.form-input:focus,
.form-textarea:focus {
  border-color: #07c160;
  background-color: #fff;
}

.form-textarea {
  height: 300rpx;
  line-height: 1.6;
}

.input-placeholder {
  color: #999;
}

.picker {
  padding: 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  background-color: #fafafa;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.form-actions {
  margin-top: 60rpx;
}

.btn-submit {
  background-color: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
}
