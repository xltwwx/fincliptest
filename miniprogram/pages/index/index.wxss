.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f3f4f6;
}

.header {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e5e7eb;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.search-box {
  background-color: #f9fafb;
  border-radius: 8rpx;
  padding: 16rpx;
}

.search-input {
  font-size: 28rpx;
  color: #374151;
}

.case-list {
  flex: 1;
  padding: 20rpx;
}

.case-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.case-type {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  margin-right: 20rpx;
  color: #fff;
}

.type-orange {
  background-color: #f97316;
}

.type-red {
  background-color: #ef4444;
}

.type-green {
  background-color: #22c55e;
}

.type-purple {
  background-color: #a855f7;
}

.case-info {
  flex: 1;
}

.case-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.case-customer {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

.case-date {
  font-size: 24rpx;
  color: #9ca3af;
}

.case-status {
  font-size: 24rpx;
  color: #6b7280;
  padding: 4rpx 12rpx;
  background-color: #f3f4f6;
  border-radius: 4rpx;
}

.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #3b82f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

.add-btn text {
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
}
