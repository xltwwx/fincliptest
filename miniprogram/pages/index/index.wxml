<!--pages/index/index.wxml-->
<view class="container">
  <!-- Header -->
  <view class="header">
    <text class="title">案例收集助手</text>
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索客户姓名或案例名称" 
        value="{{searchQuery}}"
        bindinput="onSearchInput"
      />
    </view>
  </view>

  <!-- List -->
  <scroll-view class="case-list" scroll-y="true">
    <view wx:if="{{filteredCases.length > 0}}">
      <view 
        wx:for="{{filteredCases}}" 
        wx:key="id" 
        class="case-card"
        bindtap="onCaseTap"
        data-id="{{item.id}}"
      >
        <view class="case-type {{item.type}}">{{item.type}}</view>
        <text class="case-name">{{item.name}}</text>
        <view class="case-info">
          <view class="info-item">
            <text class="info-icon">👤</text>
            <text class="info-text">{{item.customerName}}</text>
          </view>
          <view class="info-item">
            <text class="info-icon">⏱️</text>
            <text class="info-text">{{item.duration}}</text>
          </view>
          <view class="info-item">
            <text class="info-icon">📅</text>
            <text class="info-text">{{item.date}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <view wx:else class="empty-state">
      <text class="empty-text">暂无相关案例</text>
    </view>
  </scroll-view>

  <!-- Floating Action Button -->
  <view class="fab" bindtap="onAddTap">
    <text class="fab-icon">+</text>
  </view>
</view>
