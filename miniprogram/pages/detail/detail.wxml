<!--pages/detail/detail.wxml-->
<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="back-btn" bindtap="onBack">
      <text class="back-icon">←</text>
    </view>
    <text class="title">{{formData.name || '新开案例'}}</text>
    <view class="edit-btn" wx:if="{{!isNewCase}}" bindtap="onEditCase">
      <text class="edit-text">修改</text>
    </view>
    <view class="placeholder" wx:else></view>
  </view>

  <!-- Scrollable Content -->
  <scroll-view class="content" scroll-y="true">
    <!-- Basic Info -->
    <view class="card basic-info">
      <view class="form-item">
        <text class="label">客户号</text>
        <view class="input-wrapper">
          <input 
            class="input" 
            placeholder="请输入客户号" 
            value="{{formData.customerId}}"
            bindinput="onCustomerIdInput"
          />
        </view>
      </view>
      <view class="form-item">
        <text class="label">业务类型</text>
        <picker 
          mode="selector" 
          range="{{businessTypes}}" 
          value="{{businessTypeIndex}}"
          bindchange="onBusinessTypeChange"
        >
          <view class="picker-value">{{businessTypes[businessTypeIndex]}}</view>
        </picker>
      </view>
      <!-- 修改按钮区域 -->
      <view class="modify-section" wx:if="{{!isNewCase}}">
        <view class="modify-btn" bindtap="onModifyBusinessType">
          <text class="modify-icon">✏️</text>
          <text class="modify-text">修改类型</text>
        </view>
      </view>
    </view>

    <!-- Modules -->
    <view class="modules-list">
      <view 
        wx:for="{{modules}}" 
        wx:key="id" 
        class="module-card"
        bindtap="onModuleTap"
        data-module="{{item}}"
      >
        <view class="module-left">
          <view class="status-dot {{formData.recordings[item.id] ? 'active' : ''}}"></view>
          <text class="module-title">{{item.title}}</text>
        </view>
        <view class="module-action {{formData.recordings[item.id] ? 'has-recording' : ''}}">
          <text wx:if="{{formData.recordings[item.id]}}">▶</text>
          <text wx:else>🎤</text>
        </view>
      </view>
    </view>

    <!-- Submit Button -->
    <view class="submit-section">
      <button class="submit-btn" bindtap="onSubmitTap">确认提交</button>
    </view>
  </scroll-view>

  <!-- Confirm Modal -->
  <view wx:if="{{showConfirm}}" class="modal-overlay" bindtap="hideConfirm">
    <view class="modal-content" catchtap="true">
      <view class="modal-icon">✓</view>
      <text class="modal-title">确认提交</text>
      <text class="modal-desc">是否确认提交当前案例及所有模块的录音文件？</text>
      <view class="modal-buttons">
        <button class="btn-cancel" bindtap="hideConfirm">取消</button>
        <button class="btn-confirm" bindtap="confirmSubmit">确认提交</button>
      </view>
    </view>
  </view>
</view>
